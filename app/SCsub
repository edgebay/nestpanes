#!/usr/bin/env python
from misc.utility.scons_hints import *

import app_builders

Import("env")

env.app_sources = []

# translations
env.CommandNoCache(
	"#app/translations/app_translations.gen.h",
	Glob("#app/translations/po/*"),
	env.Run(app_builders.make_translations_header),
)

env.add_source_files(env.app_sources, "*.cpp")

SConscript("app_core/SCsub")
SConscript("app_modules/SCsub")
SConscript("gui/SCsub")
SConscript("themes/SCsub")
SConscript("translations/SCsub")

lib = env.add_library("app", env.app_sources)
env.Prepend(LIBS=[lib])
